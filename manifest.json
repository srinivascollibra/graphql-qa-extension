{
  "manifest_version": 3,
  "name": "GraphQL QA Panel",
  "version": "1.2.1",
  "description": "DevTools panel for testers: capture GraphQL from real sessions, highlight errors, copy for bug reports.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "devtools_page": "devtools.html",
  "minimum_chrome_version": "114",
  "permissions": ["storage", "webNavigation", "tabs"],
  "background": {
    "service_worker": "background.js"
  }
}
